[
  {
    "label": "test",
    "command": ".venv/bin/pytest",
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false
  },
  {
    "label": "lint (ruff)",
    "command": ".venv/bin/ruff check src tests",
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false
  },
  {
    "label": "build example",
    "command": ".venv/bin/cmsmig build sites/example",
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false
  },
  {
    "label": "preview example (http://localhost:5013)",
    "command": "python3 -m http.server 5013 --directory sites/example/dist",
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true
  },
  {
    "label": "forms example (様式xlsx生成)",
    "command": ".venv/bin/cmsmig forms sites/example",
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false
  },
  {
    "label": "publish example (dry-run)",
    "command": ".venv/bin/cmsmig publish sites/example --dry-run",
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false
  }
]
